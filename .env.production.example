# Copy to .env for docker compose production runs. Never commit real values.
DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:YOUR_SUPABASE_DATABASE_PASSWORD@aws-1-eu-central-1.pooler.supabase.com:5432/postgres

JWT_SECRET=CHANGE_ME_GENERATE_WITH_SECRETS_TOKEN_URLSAFE_48
JWT_ALGORITHM=HS256
TELEGRAM_BOT_TOKEN=CHANGE_ME_FROM_BOTFATHER
TELEGRAM_WEBAPP_URL=https://thepolka.app
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME_GENERATE_WITH_SECRETS_TOKEN_URLSAFE_32
ENV=production

CADDY_SITE_ADDRESS=thepolka.app,www.thepolka.app
CORS_ORIGINS=https://thepolka.app,https://www.thepolka.app,https://t.me
CORS_ORIGIN_REGEX=

NEXT_PUBLIC_API_URL=/api
